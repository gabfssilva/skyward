{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode/extension",
      "group": "build",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": [
        "$tsc-watch",
        {
          "base": "$esbuild-watch",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[watch\\] build started$",
            "endsPattern": "^\\[watch\\] build finished$"
          }
        }
      ]
    }
  ]
}
